{
  "name": "@palasthotel/headless",
  "version": "3.0.4",
  "description": "wp-rest extensions to works with headless plugin.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "test": "jest",
    "build": "tsdown",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/palasthotel/headless"
  },
  "author": "Palasthotel GmbH",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@palasthotel/wp-rest": "^1.0.2",
    "@wordpress/editor": "^14.30.0",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.11.0"
  }
}
