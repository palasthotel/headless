{
  "name": "@palasthotel/headless",
  "version": "3.0.6",
  "description": "wp-rest extensions to works with headless plugin.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "test": "jest",
    "build": "tsdown",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/palasthotel/headless"
  },
  "author": "Palasthotel GmbH",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@palasthotel/wp-rest": "^1.0.2",
    "@wordpress/editor": "^14.48.1",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.11.0"
  }
