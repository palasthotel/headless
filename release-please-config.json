{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "packages": {
    "npm-package": {
      "release-type": "node",
      "package-name": "@palasthotel/headless",
      "component": "npm",
      "changelog-path": "npm-package/CHANGELOG.md",
      "include-component-in-tag": true,
      "tag-separator": "-",
      "include-v-in-tag": true,
      "bump-minor-pre-major": false,
      "prerelease": false,
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "feature", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "docs", "section": "Documentation", "hidden": true },
        { "type": "refactor", "section": "Code Refactoring", "hidden": false },
        { "type": "chore", "section": "Miscellaneous", "hidden": false },
        { "type": "deps", "section": "Dependencies", "hidden": true }
      ]
    },
    "wp-plugin": {
      "release-type": "simple",
      "package-name": "@palasthotel/wp-headless",
      "component": "plugin",
      "changelog-path": "wp-plugin/CHANGELOG.md",
      "include-component-in-tag": true,
      "tag-separator": "-",
      "include-v-in-tag": true,
      "bump-minor-pre-major": false,
      "prerelease": false,
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "feature", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "docs", "section": "Documentation", "hidden": true },
        { "type": "refactor", "section": "Code Refactoring", "hidden": false },
        { "type": "chore", "section": "Miscellaneous", "hidden": false },
        { "type": "deps", "section": "Dependencies", "hidden": true }
      ],
      "extra-files": [
        {
          "type": "generic",
          "path": "wp-plugin/plugin/readme.txt",
          "glob": false
        },
        {
          "type": "generic",
          "path": "wp-plugin/plugin/headless.php",
          "glob": false
        },
        {
          "type": "json",
          "path": "wp-plugin/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
